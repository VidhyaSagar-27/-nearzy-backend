# ═══════════════════════════════════════════════
#  NEARZY BACKEND — Environment Variables
#  Copy this file to .env and fill in values
# ═══════════════════════════════════════════════

# Server
NODE_ENV=production
PORT=5000
FRONTEND_URL=https://your-frontend-url.com

# MongoDB Atlas
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/nearzy?retryWrites=true&w=majority

# JWT
JWT_SECRET=your_super_secret_jwt_key_min_32_chars
JWT_EXPIRES_IN=30d

# Razorpay
RAZORPAY_KEY_ID=rzp_live_SQ2a0BIeQiJQly
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Cloudinary (optional - for image uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Twilio (optional - for SMS OTP)
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_PHONE=+1234567890

# Email (optional - for email notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password

# Web Push (optional - for browser push notifications)
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_EMAIL=mailto:your@email.com
